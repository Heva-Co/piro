{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Quartz": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Quartz": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Sentry": {
    "Dsn": "",
    "Environment": "production",
    "TracesSampleRate": 0.1,
    "AttachStacktrace": true,
    "SendDefaultPii": false
  },
  "Telemetry": {}
}
