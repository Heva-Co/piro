{{~
  title_link = check_url ? ("[" + title + "](" + check_url + ")") : title
~}}
{{~ if is_recovery ~}}
✅ *RECOVERED* — {{ title_link }}

Status: `{{ current_status }}`
Time: {{ fired_at }}
{{~ else ~}}
🚨 *{{ severity }}* — {{ title_link }}

Status: `{{ current_status }}`
Severity: {{ severity }}
{{~ if alert_description ~}}
Note: {{ alert_description }}
{{~ end ~}}
Time: {{ fired_at }}
{{~ end ~}}
