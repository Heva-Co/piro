# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_use_a_long_random_string_at_least_32_chars
ACCESS_TOKEN_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=30

# Public URL of the frontend (used for CORS and redirects)
ORIGIN=https://status.example.com

# ── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=piro@example.com
EMAIL_PASSWORD=change_me
EMAIL_FROM=piro@example.com

# ── Worker ────────────────────────────────────────────────────────────────────
# Generate a token in the admin panel under Configuration > Workers
WORKER_TOKEN=change_me
WORKER_REGION=default
